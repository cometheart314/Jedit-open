<?xml version="1.0" encoding="UTF-8"?>
<document type="com.apple.InterfaceBuilder3.Cocoa.XIB" version="3.0" toolsVersion="24506" targetRuntime="MacOSX.Cocoa" propertyAccessControl="none" useAutolayout="YES" customObjectInstantitationMethod="direct">
    <dependencies>
        <plugIn identifier="com.apple.InterfaceBuilder.CocoaPlugin" version="24506"/>
        <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
    </dependencies>
    <objects>
        <customObject id="-2" userLabel="File's Owner" customClass="PrintPanelAccessoryController" customModule="Jedit_open" customModuleProvider="target">
            <connections>
                <outlet property="view" destination="c22-O7-iKe" id="view-outlet"/>
                <outlet property="lineNumberPopup" destination="lineNum-popup" id="lineNum-outlet"/>
                <outlet property="colorPopup" destination="color-popup" id="color-outlet"/>
                <outlet property="printHeaderCheckbox" destination="header-check" id="header-outlet"/>
                <outlet property="printFooterCheckbox" destination="footer-check" id="footer-outlet"/>
                <outlet property="printInvisiblesCheckbox" destination="invis-check" id="invis-outlet"/>
            </connections>
        </customObject>
        <customObject id="-1" userLabel="First Responder" customClass="FirstResponder"/>
        <customObject id="-3" userLabel="Application" customClass="NSObject"/>
        <customView id="c22-O7-iKe">
            <rect key="frame" x="0.0" y="0.0" width="300" height="160"/>
            <autoresizingMask key="autoresizingMask" flexibleMaxX="YES" flexibleMinY="YES"/>
            <subviews>
                <!-- Line Numbers Label -->
                <textField focusRingType="none" horizontalHuggingPriority="251" verticalHuggingPriority="750" fixedFrame="YES" translatesAutoresizingMaskIntoConstraints="NO" id="lineNum-label">
                    <rect key="frame" x="10" y="128" width="96" height="17"/>
                    <autoresizingMask key="autoresizingMask" flexibleMaxX="YES" flexibleMinY="YES"/>
                    <textFieldCell key="cell" scrollable="YES" lineBreakMode="clipping" sendsActionOnEndEditing="YES" alignment="right" title="Line Numbers:" id="lineNum-label-cell">
                        <font key="font" metaFont="system"/>
                        <color key="textColor" name="labelColor" catalog="System" colorSpace="catalog"/>
                        <color key="backgroundColor" name="controlColor" catalog="System" colorSpace="catalog"/>
                    </textFieldCell>
                </textField>
                <!-- Line Numbers Popup -->
                <popUpButton verticalHuggingPriority="750" fixedFrame="YES" translatesAutoresizingMaskIntoConstraints="NO" id="lineNum-popup">
                    <rect key="frame" x="110" y="123" width="180" height="26"/>
                    <autoresizingMask key="autoresizingMask" flexibleMaxX="YES" flexibleMinY="YES"/>
                    <popUpButtonCell key="cell" type="push" title="Same as Editing Window" bezelStyle="rounded" alignment="left" lineBreakMode="truncatingTail" state="on" borderStyle="borderAndBezel" imageScaling="proportionallyDown" inset="2" selectedItem="lineNum-item0" id="lineNum-popup-cell">
                        <behavior key="behavior" lightByBackground="YES" lightByGray="YES"/>
                        <font key="font" metaFont="system"/>
                        <menu key="menu" title="OtherViews" id="lineNum-menu">
                            <items>
                                <menuItem title="Same as Editing Window" state="on" tag="0" id="lineNum-item0">
                                    <modifierMask key="keyEquivalentModifierMask"/>
                                </menuItem>
                                <menuItem title="Print Line Numbers" tag="1" id="lineNum-item1">
                                    <modifierMask key="keyEquivalentModifierMask"/>
                                </menuItem>
                                <menuItem title="Don't Print Line Numbers" tag="2" id="lineNum-item2">
                                    <modifierMask key="keyEquivalentModifierMask"/>
                                </menuItem>
                            </items>
                        </menu>
                    </popUpButtonCell>
                    <connections>
                        <action selector="lineNumberPopupChanged:" target="-2" id="lineNum-action"/>
                    </connections>
                </popUpButton>
                <!-- Colors Label -->
                <textField focusRingType="none" horizontalHuggingPriority="251" verticalHuggingPriority="750" fixedFrame="YES" translatesAutoresizingMaskIntoConstraints="NO" id="color-label">
                    <rect key="frame" x="10" y="98" width="96" height="17"/>
                    <autoresizingMask key="autoresizingMask" flexibleMaxX="YES" flexibleMinY="YES"/>
                    <textFieldCell key="cell" scrollable="YES" lineBreakMode="clipping" sendsActionOnEndEditing="YES" alignment="right" title="Colors:" id="color-label-cell">
                        <font key="font" metaFont="system"/>
                        <color key="textColor" name="labelColor" catalog="System" colorSpace="catalog"/>
                        <color key="backgroundColor" name="controlColor" catalog="System" colorSpace="catalog"/>
                    </textFieldCell>
                </textField>
                <!-- Colors Popup -->
                <popUpButton verticalHuggingPriority="750" fixedFrame="YES" translatesAutoresizingMaskIntoConstraints="NO" id="color-popup">
                    <rect key="frame" x="110" y="93" width="180" height="26"/>
                    <autoresizingMask key="autoresizingMask" flexibleMaxX="YES" flexibleMinY="YES"/>
                    <popUpButtonCell key="cell" type="push" title="Same as Editing Window" bezelStyle="rounded" alignment="left" lineBreakMode="truncatingTail" state="on" borderStyle="borderAndBezel" imageScaling="proportionallyDown" inset="2" selectedItem="color-item0" id="color-popup-cell">
                        <behavior key="behavior" lightByBackground="YES" lightByGray="YES"/>
                        <font key="font" metaFont="system"/>
                        <menu key="menu" title="OtherViews" id="color-menu">
                            <items>
                                <menuItem title="Same as Editing Window" state="on" tag="0" id="color-item0">
                                    <modifierMask key="keyEquivalentModifierMask"/>
                                </menuItem>
                                <menuItem title="Don't Print Background Color" tag="1" id="color-item1">
                                    <modifierMask key="keyEquivalentModifierMask"/>
                                </menuItem>
                                <menuItem title="Black Chars and White Back" tag="2" id="color-item2">
                                    <modifierMask key="keyEquivalentModifierMask"/>
                                </menuItem>
                            </items>
                        </menu>
                    </popUpButtonCell>
                    <connections>
                        <action selector="colorPopupChanged:" target="-2" id="color-action"/>
                    </connections>
                </popUpButton>
                <!-- Print Header Checkbox -->
                <button fixedFrame="YES" translatesAutoresizingMaskIntoConstraints="NO" id="header-check">
                    <rect key="frame" x="112" y="66" width="170" height="18"/>
                    <autoresizingMask key="autoresizingMask" flexibleMaxX="YES" flexibleMinY="YES"/>
                    <buttonCell key="cell" type="check" title="Print Header" bezelStyle="regularSquare" imagePosition="left" state="on" inset="2" id="header-check-cell">
                        <behavior key="behavior" changeContents="YES" doesNotDimImage="YES" lightByContents="YES"/>
                        <font key="font" metaFont="system"/>
                    </buttonCell>
                    <connections>
                        <action selector="printHeaderChanged:" target="-2" id="header-action"/>
                    </connections>
                </button>
                <!-- Print Footer Checkbox -->
                <button fixedFrame="YES" translatesAutoresizingMaskIntoConstraints="NO" id="footer-check">
                    <rect key="frame" x="112" y="42" width="170" height="18"/>
                    <autoresizingMask key="autoresizingMask" flexibleMaxX="YES" flexibleMinY="YES"/>
                    <buttonCell key="cell" type="check" title="Print Footer" bezelStyle="regularSquare" imagePosition="left" state="on" inset="2" id="footer-check-cell">
                        <behavior key="behavior" changeContents="YES" doesNotDimImage="YES" lightByContents="YES"/>
                        <font key="font" metaFont="system"/>
                    </buttonCell>
                    <connections>
                        <action selector="printFooterChanged:" target="-2" id="footer-action"/>
                    </connections>
                </button>
                <!-- Print Invisibles Checkbox -->
                <button fixedFrame="YES" translatesAutoresizingMaskIntoConstraints="NO" id="invis-check">
                    <rect key="frame" x="112" y="18" width="170" height="18"/>
                    <autoresizingMask key="autoresizingMask" flexibleMaxX="YES" flexibleMinY="YES"/>
                    <buttonCell key="cell" type="check" title="Print Invisibles" bezelStyle="regularSquare" imagePosition="left" inset="2" id="invis-check-cell">
                        <behavior key="behavior" changeContents="YES" doesNotDimImage="YES" lightByContents="YES"/>
                        <font key="font" metaFont="system"/>
                    </buttonCell>
                    <connections>
                        <action selector="printInvisiblesChanged:" target="-2" id="invis-action"/>
                    </connections>
                </button>
            </subviews>
            <point key="canvasLocation" x="17" y="-202"/>
        </customView>
    </objects>
</document>
