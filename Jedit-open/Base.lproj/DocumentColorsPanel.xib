            </view>
            <connections>
                <outlet property="backgroundColorWell" destination="colorWell-background" id="conn-background"/>
                <outlet property="cancelButton" destination="btn-cancel" id="conn-cancel"/>
                <outlet property="caretColorWell" destination="colorWell-caret" id="conn-caret"/>
                <outlet property="characterColorWell" destination="colorWell-character" id="conn-character"/>
                <outlet property="footerColorWell" destination="colorWell-footer" id="conn-footer"/>
                <outlet property="headerColorWell" destination="colorWell-header" id="conn-header"/>
                <outlet property="highlightColorWell" destination="colorWell-highlight" id="conn-highlight"/>
                <outlet property="invisiblesColorWell" destination="colorWell-invisibles" id="conn-invisibles"/>
                <outlet property="lineNumberBackgroundColorWell" destination="colorWell-lineNumberBackground" id="conn-lineNumberBackground"/>
                <outlet property="lineNumberColorWell" destination="colorWell-lineNumber" id="conn-lineNumber"/>
                <outlet property="setButton" destination="btn-set" id="conn-set"/>
                <outlet property="themePopup" destination="popup-theme" id="conn-theme"/>
            </connections>
            <point key="canvasLocation" x="258" y="138"/>
        </window>
    </objects>
</document>
